# Backend env vars. In production these are set in Render's Environment tab.
# Locally, only DJANGO_SECRET_KEY needs to be set if you want to mimic prod;
# everything else has dev-friendly defaults.

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-50-char-random-string
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=playto-payout.onrender.com

# CORS — comma-separated origins allowed to call the API.
# Set this to your Vercel production URL (e.g. https://playto-payout.vercel.app).
# Vercel preview URLs (`*.vercel.app`) are already allowed by regex in settings.
DJANGO_CORS_ORIGINS=https://playto-payout.vercel.app

# Optional: extra CSRF trusted origins (Render's host is auto-added).
DJANGO_CSRF_TRUSTED_ORIGINS=

# --- Database ---
# DATABASE_URL is set automatically by Render when you attach a managed Postgres.
# Format: postgres://user:pass@host:port/dbname
DATABASE_URL=

# --- Redis / Celery ---
# REDIS_URL is set automatically by Render when you attach Redis.
REDIS_URL=

# --- Bank settlement simulation ---
# Optional. Forces every roll to a deterministic value. Leave unset for random.
#   < 0.7   success    < 0.9 failure (writes REVERSAL)    >= 0.9 hang
PAYOUT_SETTLEMENT_FORCE=
